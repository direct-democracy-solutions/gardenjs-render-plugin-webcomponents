{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "chore(release): Release ${version}"
  },
  "github": {
    "release": true
  },
  "npm": {
    "skipChecks": true
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "addUnreleased": true,
      "addVersionUrl": true
    }
  },
  "hooks": {
    "after:bump": "npm run build"
  }
}
